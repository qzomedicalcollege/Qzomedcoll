---
const programs = ['Лечебное дело','Сестринское дело','Акушерское дело','Фармация','Стоматология','Лабораторная диагностика','Медицинская оптика','Прикладной бакалавриат'];
---
<html lang="ru"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Специальности</title><style>body{margin:0;font-family:Inter,system-ui;background:#f3f8ff;color:#0f172a}.wrap{width:min(1100px,calc(100% - 32px));margin:auto;padding:40px 0}.top{display:flex;gap:16px;align-items:center;justify-content:space-between}.logo{font-weight:900}.btn,.card{background:white;border:1px solid #dbeafe;border-radius:24px;box-shadow:0 20px 60px #0f6fdc18}.btn{padding:12px 18px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px}.card{padding:22px}.badge{color:#0f6fdc;font-weight:900}h1{font-size:clamp(42px,8vw,86px);line-height:.9}</style></head><body><main class="wrap"><div class="top"><a class="logo" href="/Qzomedcoll/">КМВК</a><a class="btn" href="/Qzomedcoll/admissions/">Подать заявку</a></div><h1>Специальности</h1><div class="grid">{programs.map((p,i)=><div class="card"><span class="badge">0{i+1}</span><h2>{p}</h2><p>Описание программы, квалификация, срок обучения и условия поступления.</p></div>)}</div></main></body></html>